# =============================================================================
# Wealth Transformation Emails — env
# =============================================================================
# Copy to .env and fill in.

NODE_ENV=development
LOG_LEVEL=info

# --- HTTP API ---
API_PORT=4100

# --- Postgres ---
# Local: postgresql://davidwood@localhost:5432/wt_emails?sslmode=disable
# Neon (prod): postgresql://user:pass@xxx.neon.tech/wt_emails?sslmode=require
DATABASE_URL=postgresql://davidwood@localhost:5432/wt_emails?sslmode=disable

# --- SendGrid ---
# Key path is read at boot — file should contain only the API key string.
SENDGRID_API_KEY_PATH=/Users/davidwood/.iat-secrets/wt_sendgrid_api_key

# --- Sender identity (must match a verified sender in SendGrid) ---
SENDER_FROM_EMAIL=team@mail.wealthtransformation.com
SENDER_FROM_NAME=Wealth Transformation
SENDER_REPLY_TO=support@mail.wealthtransformation.com

# --- Internal shared secrets (HMAC for service-to-service) ---
# Generated with `openssl rand -base64 48`. Used by:
#  - Indexer → emails (purchase events)
#  - WT app → emails (capture form, sponsor-notify trigger)
#  - SendGrid event webhook signature verification
INTERNAL_HMAC_SECRET_PATH=/Users/davidwood/.iat-secrets/wt_emails_internal_hmac
SENDGRID_WEBHOOK_VERIFICATION_KEY_PATH=/Users/davidwood/.iat-secrets/wt_sendgrid_webhook_pubkey

# --- IAT-side lookup endpoint (for resolving wallet → email) ---
IAT_INTERNAL_LOOKUP_URL=https://api.iamtransformation.com/api/v1/internal/wallet-email
IAT_INTERNAL_HMAC_SECRET_PATH=/Users/davidwood/.iat-secrets/iat_internal_lookup_hmac

# --- WT contract (for skip-walker queries) ---
BASE_RPC_URL=https://sepolia.base.org
WT_CONTRACT_ADDRESS=0xeb83B8ce7636669FA940f57e01D7a9a3A7ddB78d
CHAIN=BASE_SEPOLIA

# --- SIWE admin auth ---
# Wallet allowed to sign in to /admin. Comma-separated.
ADMIN_ALLOWLIST=0xC9858b2CcbB0644982750e415B49528C4dEdf6E0

# --- Email volume / throughput ---
OUTBOX_BATCH_SIZE=100
OUTBOX_INTERVAL_MS=5000
SEND_RATE_LIMIT_PER_MINUTE=1000

# --- Public URLs (for confirmation + unsubscribe links) ---
PUBLIC_BASE_URL=https://wealthtransformation.com
